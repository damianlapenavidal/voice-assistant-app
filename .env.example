OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-realtime-2.1-mini
OPENAI_VOICE=alloy
# Assistant prompts live in editable markdown files under
# src/voice_assistant/prompts/. The system prompt is composed in three layers:
# base_system.md (who the assistant is) + teaching_method.md (shared language
# pedagogy) + the selected persona file.
# PERSONA selects a persona file id (without .md) from prompts/personas/.
# Available personas:
#   oso_animals    - Oso, a forest bear: animals, nature, weather
#   robi_colors    - Robi, a robot: colors, shapes, counting
#   chef_coco_food - Chef Coco, a cook: food, cooking, manners
#   luna_bedtime   - Luna, the moon: calm wind-down, feelings, family
#   pili_movement  - Pili, a wiggly friend: body, actions, movement (TPR)
# PERSONA=oso_animals
# OPENING_GREETING_PROMPT names the greeting prompt file (without .md).
# OPENING_GREETING_PROMPT=opening_greeting
# ASSISTANT_INSTRUCTIONS is an optional inline override; when set it skips the
# prompt files entirely (handy for quick experiments).
# ASSISTANT_INSTRUCTIONS=You are a friendly voice assistant for children.
# VAD thresholds are derived automatically from Pi mic calibration at session start.
DEVICE_HOST=0.0.0.0
DEVICE_PORT=8765
LOG_LEVEL=INFO
