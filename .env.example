OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-realtime-2.1-mini
OPENAI_VOICE=alloy
# Assistant prompts live in editable markdown files under
# src/voice_assistant/prompts/. The system prompt is composed from
# base_system.md + the selected persona file.
# PERSONA selects a persona file id (without .md) from prompts/personas/.
# PERSONA=oso_animals
# OPENING_GREETING_PROMPT names the greeting prompt file (without .md).
# OPENING_GREETING_PROMPT=opening_greeting
# ASSISTANT_INSTRUCTIONS is an optional inline override; when set it skips the
# prompt files entirely (handy for quick experiments).
# ASSISTANT_INSTRUCTIONS=You are a friendly voice assistant for children.
# VAD thresholds are derived automatically from Pi mic calibration at session start.
DEVICE_HOST=0.0.0.0
DEVICE_PORT=8765
LOG_LEVEL=INFO
