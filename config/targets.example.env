# Raspberry Pi target configuration -- EXAMPLE (safe to commit).
#
# Copy this to config/targets.local.env and edit it:
#     ./scripts/setup-target-config.sh
# config/targets.local.env is gitignored.
#
# NEVER put secrets here. No Wi-Fi passwords, no GitHub tokens, no OpenAI keys.
# Wi-Fi joins reuse the network already saved in macOS Keychain; the OpenAI key
# lives in .env.
#
# Every KEY is read by scripts/lib/config.sh. Unused keys are ignored, but a
# missing *required* key aborts the launcher with a message naming the key.


# =============================================================================
# Raspberry Pi 5
# =============================================================================

# Exact SSID as saved on macOS. Verify with:
#     networksetup -listpreferredwirelessnetworks en0
# It is "URI_Secure" (underscore) on this Mac -- not "URI Secure".
PI5_WIFI_SSID="URI_Secure"

# SSH alias from ~/.ssh/config. Never put an IP address here.
PI5_SSH_HOST="voice-assistant-pi5"

PI5_REMOTE_REPO="/home/damianlapenavidal/voice-assistant-pi5"
PI5_BRANCH="main"

# systemd unit that runs the Pi-side endpoint, without the ".service" suffix.
# Install it from deploy/systemd/ -- see docs/raspberry-pi-development-workflow.md.
PI5_SERVICE_NAME="voice-assistant-pi5"

# "user"   -> systemctl --user  (preferred: no sudo needed)
# "system" -> sudo systemctl    (only if the endpoint genuinely needs root)
PI5_SERVICE_SCOPE="user"

# Endpoint -> app connection. The Pi dials the app, so ENDPOINT_HOST is how the
# Pi reaches THIS MAC. Leave empty to let the launcher auto-detect the Mac's IP
# on the active Wi-Fi interface (recommended -- it changes between networks).
PI5_ENDPOINT_HOST=""
PI5_ENDPOINT_PORT="8765"
PI5_PROTOCOL="websocket"

# Seconds to wait for the endpoint to become ready after a service restart.
PI5_READY_TIMEOUT="30"

# ALSA settings for the Pi 5. Deliberately left blank: the Pi 5's audio hardware
# has NOT been inspected and is NOT assumed to match the Pi Zero 2 W. Fill these
# in only after verifying with `arecord -l` / `aplay -L` ON THE PI 5.
PI5_ALSA_CARD_ID=""
PI5_CAPTURE_DEVICE=""
PI5_PLAYBACK_DEVICE=""
PI5_SAMPLE_RATE=""
PI5_CAPTURE_FORMAT=""
PI5_CAPTURE_CHANNELS=""
PI5_MIC_CHANNEL=""
PI5_PLAYBACK_CHANNELS=""
PI5_INPUT_GAIN=""
PI5_PLAYBACK_GAIN=""


# =============================================================================
# Raspberry Pi Zero 2 W
# =============================================================================

# The iPhone hotspot SSID. This Mac has TWO similar saved networks --
# "iPhone de Damian" and "iPhone de Damián" (accented). They are different
# networks to macOS. Run setup-target-config.sh to pick the right one.
PIZERO2W_WIFI_SSID="<YOUR_IPHONE_HOTSPOT_SSID>"

PIZERO2W_SSH_HOST="voice-assistant-pizero2w"
PIZERO2W_REMOTE_REPO="/home/damianlapenavidal/voice-assistant-piZero2W"
PIZERO2W_BRANCH="main"
PIZERO2W_SERVICE_NAME="voice-assistant-pizero2w"
PIZERO2W_SERVICE_SCOPE="user"

PIZERO2W_ENDPOINT_HOST=""
PIZERO2W_ENDPOINT_PORT="8765"
PIZERO2W_PROTOCOL="websocket"
PIZERO2W_READY_TIMEOUT="45"

# --- Verified Pi Zero 2 W audio -------------------------------------------
# Confirmed on the device via /proc/asound/cards, arecord -l, aplay -l, aplay -L.
#
# The card is the googlevoicehat overlay (ICS-43434 mic + MAX98357A amp).
# It currently enumerates as card 0, but card 1 (vc4hdmi) also exists, so the
# numeric index is NOT stable -- always address the card by its ID.
PIZERO2W_ALSA_CARD_ID="sndrpigooglevoi"

# `aplay -L` on the device confirms this exact CARD= syntax is supported.
PIZERO2W_CAPTURE_DEVICE="plughw:CARD=sndrpigooglevoi,DEV=0"
PIZERO2W_PLAYBACK_DEVICE="plughw:CARD=sndrpigooglevoi,DEV=0"

PIZERO2W_SAMPLE_RATE="48000"
PIZERO2W_CAPTURE_FORMAT="S32_LE"

# The ICS-43434 is a mono mic sitting in the LEFT slot of a 2-channel I2S
# stream. Capture 2 channels and take channel 1 (left); the right channel is
# silent by design. Recording 1 channel, or taking the right slot, yields
# silence.
PIZERO2W_CAPTURE_CHANNELS="2"
PIZERO2W_MIC_CHANNEL="left"

# The MAX98357A is fed a stereo stream; the mono response is duplicated into
# both slots.
PIZERO2W_PLAYBACK_CHANNELS="2"

# Software gain. The ICS-43434's hardware sensitivity is fixed and its raw
# signal is quiet, so input gain is applied in software. This is a steady
# multiplier -- do NOT normalize realtime chunks individually, which pumps the
# noise floor between chunks.
PIZERO2W_INPUT_GAIN="1.0"

# Playback gain. 0.35 is the SoX `vol` factor that sounded comfortable during
# manual record-then-play testing (see scripts/audio-diagnostic.sh). It is a
# calibration starting point for this speaker, not a proven realtime PCM
# multiplier -- raise or lower it by ear, and keep it low enough not to clip.
PIZERO2W_PLAYBACK_GAIN="0.35"
